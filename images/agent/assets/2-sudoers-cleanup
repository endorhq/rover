Defaults env_reset
Defaults env_keep += "HOME"
Defaults env_keep += "RUST_LOG"

# Rover agent group; if there is no matching gid within the container
# with the host gid, the `agent` group will be used.
%agent ALL=(ALL) NOPASSWD: /bin/chown,/bin/cp,/bin/mv,/usr/bin/tee,/usr/local/bin/rover-agent-install

# Original image group list at /etc/group. If the host user gid
# matches with any of them, it will be able to use `sudo` normally
# within the container.
%root ALL=(ALL) NOPASSWD: /bin/chown,/bin/cp,/bin/mv,/usr/bin/tee,/usr/local/bin/rover-agent-install,/usr/local/bin/package-manager-mcp-server
